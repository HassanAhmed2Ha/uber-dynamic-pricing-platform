.pytest_cache/
htmlcov/
.coverage
*.cover

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
*.env

# ---- OS & Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---- Logs ----
logs/
*.log
